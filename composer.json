{
    "name": "uptools-io/elallas-for-woo",
    "description": "Online withdrawal (elállás) button and case management for WooCommerce — EU 2023/2673 / 415/2025 compliant",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "uptools.io",
            "homepage": "https://uptools.io"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "^2.0",
        "dompdf/dompdf": "^3.0"
    },
    "require-dev": {
        "php-stubs/woocommerce-stubs": "^9.0",
        "php-stubs/wp-cli-stubs": "^2.10",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.0",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LightweightPlugins\\Elallas\\": "includes/"
        },
        "files": [
            "includes/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "LightweightPlugins\\Elallas\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true,
        "platform": {
            "php": "8.0.30"
        }
    },
    "extra": {
        "strauss": {
            "target_directory": "vendor-prefixed",
            "namespace_prefix": "LightweightPlugins\\Elallas\\Vendor\\",
            "classmap_prefix": "LightweightPlugins_Elallas_Vendor_",
            "constant_prefix": "ELALLAS_VENDOR_",
            "packages": [
                "dompdf/dompdf",
                "dompdf/php-font-lib",
                "dompdf/php-svg-lib",
                "masterminds/html5",
                "sabberworm/php-css-parser",
                "thecodingmachine/safe"
            ],
            "delete_vendor_packages": true
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "analyse": "phpstan analyse --memory-limit=2G",
        "test": "phpunit"
    }
}
